{
  "name": "auralis",
  "version": "0.1.0",
  "description": "A quiet local music archive built with Electron, Vue, TypeScript, and SQLite.",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "set AURALIS_QUIET_GPU_LOGS=1&& electron-vite dev",
    "dev:no-direct-composition": "set AURALIS_DISABLE_DIRECT_COMPOSITION=1&& electron-vite dev",
    "dev:verbose-gpu": "electron-vite dev",
    "dev:software-rendering": "set AURALIS_SOFTWARE_RENDERING=1&& electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "preview": "electron-vite preview",
    "rebuild:native": "set USERPROFILE=%CD%\\.electron-home&& set HOME=%CD%\\.electron-home&& electron-rebuild -f -w better-sqlite3",
    "typecheck": "vue-tsc -p tsconfig.web.json --noEmit --tsBuildInfoFile .electron-home/tsconfig.web.tsbuildinfo && tsc -p tsconfig.node.json --noEmit --tsBuildInfoFile .electron-home/tsconfig.node.tsbuildinfo",
    "lint": "eslint src electron.vite.config.ts eslint.config.js uno.config.ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@applemusic-like-lyrics/core": "^0.5.1",
    "@motionone/dom": "^10.18.0",
    "@pixi/app": "^7.4.3",
    "@pixi/core": "^7.4.3",
    "@pixi/display": "^7.4.3",
    "@pixi/filter-blur": "^7.4.3",
    "@pixi/filter-bulge-pinch": "^5.1.1",
    "@pixi/filter-color-matrix": "^7.4.3",
    "@pixi/sprite": "^7.4.3",
    "@tanstack/vue-virtual": "^3.13.12",
    "@vueuse/core": "^12.8.2",
    "better-sqlite3": "^11.9.1",
    "music-metadata": "^11.13.0",
    "opencc-js": "^1.4.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^4.0.4",
    "@iconify-json/lucide": "^1.2.114",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.4.0",
    "electron": "^38.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.0.0",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.5.3",
    "typescript": "~5.7.3",
    "unocss": "^0.65.4",
    "vite": "^6.2.2",
    "vue-tsc": "^2.2.8"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "build": {
    "appId": "com.bobo.auralis",
    "productName": "Auralis",
    "copyright": "Copyright © 2026 BoBo",
    "directories": {
      "output": "release"
    },
    "icon": "resources/icons/icon.ico",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/icons/icon.png",
        "to": "icons/icon.png"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "icon": "resources/icons/icon.ico",
      "signAndEditExecutable": true,
      "signExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
